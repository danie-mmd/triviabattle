# ─── Telegram ───────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here

# ─── JWT ────────────────────────────────────
JWT_SECRET=change_me_to_a_random_256bit_secret
JWT_EXPIRY_MS=86400000

# ─── MySQL ──────────────────────────────────
MYSQL_URL=jdbc:mysql://localhost:3306/triviabattle
MYSQL_USERNAME=trivia
MYSQL_PASSWORD=trivia_pass

# ─── Redis ──────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Gemini AI ──────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── TON Blockchain ─────────────────────────
TON_AUTHORIZED_WALLET=EQC...your_backend_wallet_address
TON_NETWORK=testnet

# ─── GCP / Cloud Run ────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
CLOUD_RUN_REGION=us-central1

# ─── Frontend (Vite) ────────────────────────
VITE_API_BASE_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080/ws/game
VITE_TON_MANIFEST_URL=https://your-app.web.app/tonconnect-manifest.json
