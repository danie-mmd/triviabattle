{
  "name": "trivia-battle-contracts",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "blueprint build",
    "test": "jest",
    "deploy": "blueprint run",
    "deploy:test": "cp .env.test .env && blueprint run --testnet --mnemonic deployEscrow",
    "deploy:prod": "cp .env.production .env && blueprint run --mainnet --mnemonic deployEscrow"
  },
  "devDependencies": {
    "@tact-lang/compiler": "^1.6.5",
    "@ton/blueprint": "^0.44.2",
    "@ton/core": "^0.63.1",
    "@ton/sandbox": "^0.40.0",
    "@ton/ton": "^16.2.4",
    "@types/jest": "^29.5.12",
    "@ton-community/func-js": "^0.10.0",
    "@ton/tolk-js": "^0.13.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.2",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testPathPattern": "tests/.*\\.spec\\.ts$"
  },
  "dependencies": {
    "@ton/crypto": "^3.3.0"
  }
}
